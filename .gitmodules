[submodule "verilator/master"]
	path = verilator/master
	url = ../../verilator/verilator
[submodule "verilator/randomize-constraints"]
	path = verilator/randomize-constraints
	url = ../verilator-1
	branch = randomize-constraints-crave
[submodule "uvm"]
	path = uvm
	url = git@github.com:antmicro/uvm-verilator.git
	branch = current-patches
[submodule "third_party/veer-el2"]
	path = third_party/veer-el2
	url = https://github.com/chipsalliance/Cores-VeeR-EL2
